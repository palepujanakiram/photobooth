# Copy to `mcp.env` in this directory and replace the placeholder.
#
# Bugsnag personal access token for the Data Access API (MCP / Cursor).
# NOT the same as the Flutter notifier key in photobooth/.env.
#
# Create one at: https://app.bugsnag.com → Settings → Organization settings → Access tokens
# Required permissions: Read projects, Read and write errors, Read and write comments
BUGSNAG_API_KEY=80f7ddc5-30bf-420e-b54e-6849a8550cbd
