# frozen_string_literal: true

# Fastlane for Android + iOS. Run from photobooth/:
#   bundle exec fastlane android generatebuild   # → Google Play Console (+ Firebase App Distribution)
#   bundle exec fastlane ios generatebuild       # → App Store Connect (TestFlight)
#   bundle exec fastlane android build     # build AAB only
#   bundle exec fastlane ios build         # build IPA only

require_relative 'fastfile_helpers'

opt_out_usage

def in_photobooth_root(&block)
  Dir.chdir(PhotoboothFastfile.photobooth_root, &block)
end

# --- Android distribution config (edit these values) ---
FIREBASE_TOKEN = 'your_firebase_ci_token_here' # firebase login:ci
FIREBASE_ANDROID_APP_ID = '1:76160113818:android:196bb713e591f09c0bd323'
FIREBASE_ANDROID_GROUPS = 'testers'
PLAY_STORE_JSON_KEY_PATH = File.expand_path('credentials/play-store-service-account.json', __dir__)
PLAY_STORE_TRACK = 'internal'
ANDROID_PACKAGE_NAME = 'com.srisarani.fotozenai'

# --- iOS / App Store Connect config (edit these values) ---
IOS_BUNDLE_IDENTIFIER = 'com.srisarani.fotozenai'
IOS_TEAM_ID = 'WR859F2ZHY'
IOS_EXPORT_OPTIONS_PLIST = File.join(PhotoboothFastfile.photobooth_root, 'ios/ExportOptions.plist')
APP_STORE_CONNECT_KEY_ID = '3Y28UQD6SG'
APP_STORE_CONNECT_ISSUER_ID = 'cbbdda4e-337b-47d3-970b-297d14aee134'
APP_STORE_CONNECT_API_KEY_PATH = File.expand_path('credentials/AuthKey_3Y28UQD6SG.p8', __dir__)

PLAY_STORE_TRACKS = %w[internal alpha beta production].freeze

def log_build_version(build_label)
  info = PhotoboothFastfile.app_version
  UI.message("App version: #{info[:version_name]}")
  UI.message("Version code: #{info[:version_code]}")
  UI.message("Starting #{build_label}...")
end

def sync_build_version!(build_number: nil)
  cmd = 'dart run tool/sync_build_version.dart'
  cmd += " --build-number=#{build_number}" unless build_number.nil?
  in_photobooth_root { sh(cmd) }
end

def play_store_version_codes_for_track(track)
  google_play_track_version_codes(
    package_name: ANDROID_PACKAGE_NAME,
    track: track,
    json_key: PLAY_STORE_JSON_KEY_PATH
  )
rescue StandardError => e
  UI.important("Could not read version codes for Play track '#{track}': #{e.message}")
  []
end

def latest_play_store_version_code
  PLAY_STORE_TRACKS.flat_map { |track| play_store_version_codes_for_track(track) }.map(&:to_i).max.to_i
end

def sync_android_build_version!
  version_name = PhotoboothFastfile.release_version_name
  latest = latest_play_store_version_code
  next_build = latest + 1
  UI.message("Play Store latest version code (all tracks): #{latest}")
  UI.message("Release version name: #{version_name}")
  UI.message("Next Android version code: #{next_build}")
  sync_build_version!(build_number: next_build)
end

def sync_ios_build_version!
  version_name = PhotoboothFastfile.release_version_name
  latest = latest_testflight_build_number(
    api_key: load_app_store_connect_api_key,
    app_identifier: IOS_BUNDLE_IDENTIFIER,
    version: version_name,
    initial_build_number: 0
  )
  UI.message("App Store latest build for #{version_name}: #{latest}")
  UI.message("Next iOS build number: #{latest.to_i + 1}")
  sync_build_version!(build_number: latest.to_i + 1)
end

def validate_android_distribution_config!
  assert_firebase_token!
  assert_firebase_android_app_id!
  assert_play_store_key!
end

def validate_ios_distribution_config!
  assert_app_store_connect_key_id!
  assert_app_store_connect_issuer_id!
  assert_app_store_connect_api_key!
  assert_ios_export_options!
end

def assert_firebase_token!
  return unless PhotoboothFastfile.firebase_token_missing?(FIREBASE_TOKEN)

  UI.user_error!('Set FIREBASE_TOKEN in fastlane/Fastfile (from `firebase login:ci`).')
end

def assert_firebase_android_app_id!
  return unless FIREBASE_ANDROID_APP_ID.nil? || FIREBASE_ANDROID_APP_ID.empty?

  UI.user_error!('Set FIREBASE_ANDROID_APP_ID in fastlane/Fastfile.')
end

def assert_play_store_key!
  return if File.exist?(PLAY_STORE_JSON_KEY_PATH)

  UI.user_error!(
    "Play Store key not found at #{PLAY_STORE_JSON_KEY_PATH}. " \
    'Place the service account JSON there or update PLAY_STORE_JSON_KEY_PATH in Fastfile.'
  )
end

def assert_app_store_connect_key_id!
  return unless PhotoboothFastfile.app_store_connect_key_id_missing?(APP_STORE_CONNECT_KEY_ID)

  UI.user_error!(
    'Set APP_STORE_CONNECT_KEY_ID in fastlane/Fastfile ' \
    '(App Store Connect → Users and Access → Integrations → App Store Connect API).'
  )
end

def assert_app_store_connect_issuer_id!
  return unless PhotoboothFastfile.app_store_connect_issuer_id_missing?(APP_STORE_CONNECT_ISSUER_ID)

  UI.user_error!('Set APP_STORE_CONNECT_ISSUER_ID in fastlane/Fastfile.')
end

def assert_app_store_connect_api_key!
  return if File.exist?(APP_STORE_CONNECT_API_KEY_PATH)

  UI.user_error!(
    "App Store Connect API key not found at #{APP_STORE_CONNECT_API_KEY_PATH}. " \
    'Download the .p8 key from App Store Connect and save it there.'
  )
end

def assert_ios_export_options!
  return if File.exist?(IOS_EXPORT_OPTIONS_PLIST)

  UI.user_error!("Export options plist not found at #{IOS_EXPORT_OPTIONS_PLIST}.")
end

def assert_bugsnag_api_key!
  in_photobooth_root do
    sh('source scripts/load_env.sh && load_photobooth_env "$(pwd)" && test -n "${BUGSNAG_API_KEY:-}"')
  end
rescue StandardError
  UI.user_error!(
    'BUGSNAG_API_KEY is required for release builds. ' \
    'Add it to photobooth/.env (see .env.example) or set the BUGSNAG_API_KEY env var (CI).'
  )
end

def build_android_aab
  log_build_version('Android App Bundle (AAB)')
  assert_bugsnag_api_key!
  in_photobooth_root { sh('./scripts/flutter_with_version.sh build appbundle --release') }
  path = PhotoboothFastfile.android_aab_path
  UI.user_error!("AAB not found at #{path}") unless File.exist?(path)
end

def build_ios_ipa
  log_build_version('iOS IPA')
  assert_bugsnag_api_key!
  in_photobooth_root do
    sh("./scripts/flutter_with_version.sh build ipa --release --export-options-plist=#{IOS_EXPORT_OPTIONS_PLIST}")
  end
  ipa = Dir.glob(PhotoboothFastfile.ios_ipa_glob).first
  UI.user_error!('IPA not found under build/ios/ipa/') unless ipa
  ipa
end

def distribute_android_aab_to_firebase
  firebase_app_distribution(
    app: FIREBASE_ANDROID_APP_ID,
    aab_path: PhotoboothFastfile.android_aab_path,
    firebase_cli_token: FIREBASE_TOKEN,
    groups: FIREBASE_ANDROID_GROUPS,
    release_notes: PhotoboothFastfile.default_release_notes
  )
end

def upload_android_aab_to_play_store
  upload_to_play_store(
    track: PLAY_STORE_TRACK,
    aab: PhotoboothFastfile.android_aab_path,
    package_name: ANDROID_PACKAGE_NAME,
    json_key: PLAY_STORE_JSON_KEY_PATH,
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true,
    skip_upload_changelogs: true
  )
end

def load_app_store_connect_api_key
  app_store_connect_api_key(
    key_id: APP_STORE_CONNECT_KEY_ID,
    issuer_id: APP_STORE_CONNECT_ISSUER_ID,
    key_filepath: APP_STORE_CONNECT_API_KEY_PATH,
    duration: 1200,
    in_house: false
  )
end

def upload_ios_ipa_to_app_store_connect(ipa_path)
  upload_to_testflight(
    api_key: load_app_store_connect_api_key,
    ipa: ipa_path,
    app_identifier: IOS_BUNDLE_IDENTIFIER,
    skip_waiting_for_build_processing: false,
    wait_processing_interval: 30,
    wait_processing_timeout_duration: 3600
  )
end

default_platform(:android)

platform :android do
  desc 'Sync version, build release AAB, upload to Google Play Console, and distribute via Firebase App Distribution'
  lane :generatebuild do
    validate_android_distribution_config!
    sync_android_build_version!
    build_android_aab
    upload_android_aab_to_play_store
    distribute_android_aab_to_firebase
  end

  desc 'Sync version and build release AAB only (no upload)'
  lane :build do
    validate_android_distribution_config!
    sync_android_build_version!
    build_android_aab
  end
end

platform :ios do
  desc 'Sync version, build release IPA, and upload to App Store Connect (TestFlight)'
  lane :generatebuild do
    validate_ios_distribution_config!
    sync_ios_build_version!
    ipa = build_ios_ipa
    upload_ios_ipa_to_app_store_connect(ipa)
  end

  desc 'Sync version and build release IPA only (no upload)'
  lane :build do
    validate_ios_distribution_config!
    sync_ios_build_version!
    build_ios_ipa
  end
end
